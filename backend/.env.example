# Optional Modal runtime configuration
EVO2_MODEL_NAME=evo2_7b
EVO2_GPU_TYPE=H100
EVO2_WINDOW_SIZE=8192
EVO2_IDLE_TIMEOUT=120
EVO2_MAX_CONTAINERS=1

# Use "*" for local testing, or comma-separated production origins:
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
CORS_ORIGINS=*
